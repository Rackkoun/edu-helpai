# .env.example
# Copy to .env and fill in real values
# Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_hex(32))"

# app
DEBUG=false
ENVIRONMENT=development

# database
DATABASE_URL=sqlite:///./data/edu_helpai.db
# postgresql: DATABASE_URL=postgresql+asyncpg://user:password@localhost/eduhelpai

# ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b

# mlflow
MLFLOW_TRACKING_URI=sqlite:///./data/mlflow.db

# security REQUIRED, minimum 32 characters
SECRET_KEY=